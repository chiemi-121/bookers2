<%= turbo_frame_tag dom_id(book, :favorite) do %>
  <% if book.favorited_by?(current_user) %>
    <%# 削除はDELETEメソッドを強制 %>
    <%= form_with url: book_favorite_path(book), method: :delete do |f| %>
      <%= f.button "♥ #{book.favorites.count}", type: "submit", class: "btn btn-link" %>
    <% end %>
  <% else %>
    <%# 作成はPOSTメソッドを強制 %>
    <%= form_with url: book_favorite_path(book), method: :post do |f| %>
      <%= f.button "♡ #{book.favorites.count}", type: "submit", class: "btn btn-link" %>
    <% end %>
  <% end %>
<% end %>
