<div id="favorite_btn_<%= book.id %>">
  <% if book.favorited_by?(current_user) %>
    <%= button_to "♥#{book.favorites.count}", book_favorite_path(book), method: :delete, data: { turbo_stream: true } %>
  <% else %>
    <%= button_to "♡#{book.favorites.count}", book_favorite_path(book), method: :post, data: { turbo_stream: true } %>
  <% end %>
</div>
