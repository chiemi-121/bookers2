<div class="mt-3">

  <%# 1. 件数表示エリア (Turbo Streamでここだけ書き換える) %>
  <div id="comment_count_area">
    <p>DEBUG: コメントは <%= book.book_comments.count %> 件あります</p>
  </div>

  <%# 2. コメント一覧エリア (ここに新しいコメントを追加したり、削除したりする) %>
  <div id="comments_list_area">
  <% @book_comments.each do |book_comment| %>
    <div id="book_comment_<%= book_comment.id %>">
      <p>
        <%= book_comment.user.name %>: <%= book_comment.comment %>
        
        <%# ★ここが判定の肝です %>
        <% if book_comment.user == current_user %>
          <%= button_to "Destroy", book_book_comment_path(book_comment.book, book_comment), 
              method: :delete, 
              data: { turbo_submits_with: "削除中..." }, 
              class: "btn btn-sm btn-danger" %>
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
</div>

<%# 3. フォームエリア (送信後にこの中身を入れ替えて文字を消す) %>
<div id="comment_form">
  <%= form_with model: [book, BookComment.new], local: false, data: { turbo_submits_with: "送信中..." } do |f| %>
    <%= f.text_area :comment, rows: '5', placeholder: "コメントをここに" %>
    <%= f.submit "送信" %>
  <% end %>
</div>