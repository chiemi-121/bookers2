<% book.book_comments.each do |book_comment| %>
  <p>
    <%= image_tag book_comment.user.get_profile_image(50,50) %>
    <%= book_comment.user.name %>
    <%= book_comment.comment %>
    
    <%# ここで、自分自身のコメントかどうかをしっかりチェック %>
    <% if book_comment.user_id == current_user.id %>
      <%= button_to "Destroy", book_book_comment_path(book_comment.book, book_comment), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-danger" %>
    <% end %>
  </p>
<% end %>