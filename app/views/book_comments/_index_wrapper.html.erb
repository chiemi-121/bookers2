<%= turbo_frame_tag "comment_index" do %>
  <div class="mt-3">
    <%= render "book_comments/index", book: book %>
  </div>

  <div class="mt-3">
    <%= form_with model: [book, BookComment.new], data: { turbo: true } do |f| %>
      <%= f.text_area :comment, rows: '5', placeholder: "コメントをここに" %>
      <%= f.submit "送信" %>
    <% end %>
  </div>
<% end %>