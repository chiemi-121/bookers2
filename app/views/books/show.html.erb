<div class="container px-5 px-sm-0 mt-3">
  <div class="row">
    <!-- 🌐 左側：共通サイドバー（3カラム分） -->
    <div class="col-md-3">
      <h2>User info</h2>
      <table class="table">
        <tbody>
          <tr>
            <th>name</th>
            <%# 💡 ログイン中の人ではなく、「その本を投稿したユーザー」の情報を表示します %>
            <th><%= @user.name %></th>
          </tr>
          <tr>
            <th>introduction</th>
            <th></th>
          </tr>
        </tbody>
      </table>
      
      <div class="row mb-3">
        <%= link_to "プロフィール編集（仮）", root_path, class: "btn btn-outline-secondary btn-block" %>
      </div>

      <h2 class="mt-3">New book</h2>
      <%# 💡 コントローラで新しく用意した @new_book を使ってフォームを作ります %>
      <%= form_with model: @new_book, local: true do |form| %>
        <div class="mb-3">
          <%= form.label :title, "Title", class: "form-label" %>
          <%= form.text_field :title, required: true, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= form.label :body, "Opinion", class: "form-label" %>
          <%= form.text_area :body, required: true, class: "form-control" %>
        </div>
        <div>
          <%= form.submit "Create Book", class: "btn btn-success" %>
        </div>
      <% end %>
    </div>

    <!-- 🌐 右側：本の詳細エリア（9カラム分） -->
    <div class="col-md-8 offset-md-1">
      <h2>Book detail</h2>
      <table class="table">
        <tbody>
          <tr>
            <td>
              <%# 投稿者の画像（仮）と名前 %>
              ユーザー画像<br>
              <%= @user.name %>
            </td>
            <td><%= @book.title %></td>
            <td><%= @book.body %></td>
            
            <%# 💡 もし「今ログインしている人」と「この本の投稿者」が同じなら、編集・削除ボタンを出す %>
            <% if @user == Current.user %>
              <td><%= link_to "Edit", edit_book_path(@book), class: "btn btn-sm btn-success" %></td>
              <td><%= link_to "Destroy", book_path(@book), data: { turbo_method: :delete, turbo_confirm: "本当に消しますか？" }, class: "btn btn-sm btn-danger" %></td>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>
  </div>