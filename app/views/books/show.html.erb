<div class="container px-5 px-sm-0 mt-3">
  <div class="row">
    
    <%# サイドバー部分 %>
    <div class="col-md-3">
      <h2>User info</h2>
      <%= render 'users/info', user: @book.user %>
      <h2 class="mt-3">New book</h2>
      <%= render 'books/form', book: @new_book %>
    </div>
    
    <%# 詳細表示部分 %>
    <div class="col-md-8 offset-md-1">
      <h2>Book detail</h2>
      <table class="table">
        <tbody>
          <tr>
            <td>
              <%= link_to user_path(@book.user) do %>
                <% if @book.user.profile_image.attached? %>
                  <%= image_tag @book.user.profile_image, size: "40x40" %><br>
                <% else %>
                  <%= image_tag "no_image.jpg", size: "40x40" %><br>
                <% end %>
                <%= @book.user.name %>
              <% end %>
            </td>
            <td><%= link_to @book.title, book_path(@book) %></td>
            <td><%= @book.body %></td>
            
            <%# 自分の投稿の場合のみ編集・削除を表示 %>
            <% if @book.user == current_user %>
              <td><%= link_to 'Edit', edit_book_path(@book), class: "btn btn-sm btn-success" %></td>
              <td><%= link_to 'Destroy', book_path(@book), method: :delete, data: { confirm: '本当に削除しますか？' }, class: "btn btn-sm btn-danger" %></td>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>
    
  </div>
</div>