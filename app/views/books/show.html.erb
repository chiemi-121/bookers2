<div class="container px-5 px-sm-0 mt-3">
  <div class="row">
    <div class="col-md-3">
      <h2>User info</h2>
      <%= render 'users/info', user: @book.user %>
      <h2 class="mt-3">New book</h2>
      <%= render 'books/form', book: @new_book %>
    </div>
    
    <div class="col-md-8 offset-md-1">
      <h2>Book detail</h2>
      <table class="table">
        <tbody>
          <tr>
            <td>
              <%= link_to user_path(@book.user) do %>
                <% if @book.user.profile_image.attached? %>
                  <%= image_tag @book.user.profile_image, size: "40x40" %><br>
                <% else %>
                  <%= image_tag "no_image.jpg", size: "40x40" %><br>
                <% end %>
                <%= @book.user.name %>
              <% end %>
            </td>
            <td><%= link_to @book.title, book_path(@book) %></td>
            <td><%= @book.body %></td>
            <td>
              <% if @book.favorited_by?(current_user) %>
                  <%= button_to book_favorite_path(@book), method: :delete, class: "btn btn-link", data: { turbo: false } do %>
                     ♥<%= @book.favorites.count %>
                  <% end %>
              <% else %>
                  <%= button_to book_favorite_path(@book), method: :post, class: "btn btn-link", data: { turbo: false } do %>
                     ♡<%= @book.favorites.count %>
                  <% end %>
               <% end %>
            </td>
            <td>コメント数: <%= @book.book_comments.count %></td>
            
            <% if @book.user == current_user %>
              <td><%= link_to 'Edit', edit_book_path(@book), class: "btn btn-sm btn-success" %></td>
              <td><%= link_to 'Destroy', book_path(@book), method: :delete, data: { confirm: '本当に削除しますか？' }, class: "btn btn-sm btn-danger" %></td>
            <% end %>
          </tr>
        </tbody>
      </table>

      <%# テーブルの外側にコメントを表示 %>
      <div class="mt-3">
        <% @book.book_comments.each do |book_comment| %>
          <p>
            <%= image_tag book_comment.user.get_profile_image(50,50) %>
            <%= book_comment.user.name %>
            <%= book_comment.comment %>
            <% if book_comment.user == current_user %>
            <%= button_to "Destroy", book_book_comment_path(book_comment.book, book_comment), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-danger" %>
            <% end %>
          </p>
        <% end %>
      </div>

      <div class="mt-3">
        <%= form_with model: [@book, @book_comment] do |f| %>
          <%= f.text_area :comment, rows: '5', placeholder: "コメントをここに" %>
          <%= f.submit "送信" %>
        <% end %>
      </div>
    </div>
  </div>
</div>