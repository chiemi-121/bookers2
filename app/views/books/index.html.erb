<%# app/views/books/index.html.erb %>

<div class="container px-5 px-sm-0 mt-3">
  <%# バリデーションエラーがあった場合の表示エリア %>
  <% if @book.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h3><%= @book.errors.count %> errors prohibited this book from being saved:</h3>
      <ul>
        <% @book.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <!-- 🌐 左側：共通サイドバー（3カラム分） -->
    <div class="col-md-3">
      <h2>User info</h2>
      <table class="table">
        <tbody>
          <tr>
            <th>name</th>
            <th><%= Current.user.name %></th>
          </tr>
          <tr>
            <th>introduction</th>
            <th><%# 自己紹介文は後ほどUserモデルを拡張した際に表示します %></th>
          </tr>
        </tbody>
      </table>
      
      <%# プロフィール編集ボタン（のちほどUser編集機能を実装したらリンクを繋ぎます） %>
      <div class="row mb-3">
        <%= link_to "プロフィール編集（仮）", root_path, class: "btn btn-outline-secondary btn-block" %>
      </div>

      <h2 class="mt-3">New book</h2>
      <%= form_with model: @book, local: true do |form| %>
        <div class="mb-3">
          <%= form.label :title, "Title", class: "form-label" %>
          <%= form.label :body, "Opinion", class: "form-label" %>
        </div>
        <div class="mb-3">
          <%= form.label :title, "Title", class: "form-label" %>
          <%= form.label :body, "Opinion", class: "form-label" %>
        </div>
        <div>
          <%= form.submit "Create Book", class: "btn btn-success" %>
        </div>
      <% end %>
    </div>

    <!-- 🌐 右側：本の一覧エリア（9カラム分） -->
    <div class="col-md-8 offset-md-1">
      <h2>Books</h2>
      <table class="table table-hover table-inverse">
        <thead>
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
            <th colspan="3"></th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%# 投稿したユーザーのアイコン画像（のちほどRefile/ActiveStorage実装時に画像にします） %>
                ユーザー画像
              </td>
              <td>
                <%# 本のタイトル（クリックすると詳細画面へ行くリンクにします。今は仮でrootへ） %>
                <%= link_to book.title, book_path(book) %>
              </td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>