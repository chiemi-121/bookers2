<div class="container px-5 px-sm-0 mt-3">
  <!-- 💡 エラーメッセージを最上部に表示 -->
  <%= render 'layouts/error_messages', model: @book %>

  <div class="row">
    <!-- 🌐 左側：User info ＆ New book（3カラム分） -->
    <div class="col-md-3">
      <h2>User info</h2>
      
      <!-- プロフィール画像 -->
      <% if Current.user.profile_image.attached? %>
        <%= image_tag Current.user.profile_image, size: "100x100", class: "attachment user profile_image" %>
      <% else %>
        <%= image_tag "no_image.jpg", size: "100x100", class: "attachment user profile_image" %>
      <% end %>

      <table class="table">
        <tbody>
          <tr>
            <th>name</th>
            <th><%= Current.user.name %></th>
          </tr>
          <tr>
            <th>introduction</th>
            <th><%= Current.user.introduction %></th>
          </tr>
        </tbody>
      </table>
      
      <!-- プロフィール編集ボタン -->
      <div class="row mb-3">
        <%= link_to edit_user_path(Current.user), class: "btn btn-outline-secondary btn-block" do %>
          <i class="fas fa-user-cog"></i>
        <% end %>
      </div>

      <!-- 新規投稿フォーム -->
      <h2 class="mt-3">New book</h2>
      <%= form_with model: @book, local: true do |form| %>
        <div class="mb-3">
          <%= form.label :title, "Title", class: "form-label" %>
          <%= form.text_field :title, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= form.label :body, "Opinion", class: "form-label" %>
          <%= form.text_area :body, class: "form-control" %>
        </div>
        <div>
          <%= form.submit "Create Book", class: "btn btn-success" %>
        </div>
      <% end %>
    </div>

    <!-- 🌐 右側：Books 一覧（9カラム分、少し左に余白を空ける） -->
    <div class="col-md-8 offset-md-1">
      <h2>Books</h2>
      <table class="table table-hover table-inverse">
        <thead>
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
            <th colspan="3"></th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <!-- 投稿したユーザーのマイページへのリンク画像 -->
                <%= link_to user_path(book.user) do %>
                  <% if book.user.profile_image.attached? %>
                    <%= image_tag book.user.profile_image, size: "40x40" %>
                  <% else %>
                    <%= image_tag "no_image.jpg", size: "40x40" %>
                  <% end %>
                <% end %>
              </td>
              <td><%= link_to book.title, book_path(book) %></td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>