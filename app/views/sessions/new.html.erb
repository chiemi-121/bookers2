<div class="container mt-5">
  <div class="row">
    <div class="col-sm-12 col-md-8 col-lg-5 mx-auto">
      <h2>Log in</h2>

      <%= form_with url: session_path, local: true do |form| %>
        <div class="mb-3">
          <%= form.label :name, "Name", class: "form-label" %>
          <!-- 💡 required: true を完全に消しました！ -->
          <%= form.text_field :name, autofocus: true, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :password, "Password", class: "form-label" %>
          <!-- 💡 required: true を完全に消しました！ -->
          <%= form.password_field :password, autocomplete: "current-password", class: "form-control" %>
        </div>

        <div>
          <%= form.submit "Log in", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>
</div>