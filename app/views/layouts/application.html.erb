<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bookers2" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <!-- ロゴ -->
        <%= link_to "Bookers", root_path, class: "navbar-brand font-weight-bold" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
<div class="collapse navbar-collapse justify-content-end" id="navbarNav">
  <ul class="navbar-nav ms-auto">
    <% if user_signed_in? %>
      <li class="nav-item">
        <%= link_to user_path(current_user.id), class: "nav-link text-light px-3" do %>
          <i class="fas fa-home"></i> Home
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to users_path, class: "nav-link text-light px-3" do %>
          <i class="fas fa-users"></i> Users
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to books_path, class: "nav-link text-light px-3" do %>
          <i class="fas fa-book-open"></i> Books
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link text-light px-3" do %>
          <i class="fas fa-sign-out-alt"></i> Log out
        <% end %>
      </li>
    <% else %>
      <li class="nav-item">
        <%= link_to root_path, class: "nav-link text-light px-3" do %>
          <i class="fas fa-home"></i> Home
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to about_path, class: "nav-link text-light px-3" do %>
          <i class="fas fa-link"></i> About
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to new_user_registration_path, class: "nav-link text-light px-3" do %>
          <i class="fas fa-user-plus"></i> Sign up
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to new_user_session_path, class: "nav-link text-light px-3" do %>
          <i class="fas fa-sign-in-alt"></i> Log in
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
        
      </div>
    </header>

    <!-- 💡 通知メッセージ表示エリア -->
    <div class="container mt-3">
      <% if flash[:notice] %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= flash[:alert] %>
        </div>
      <% end %>
    </div>

    
    <%= yield %>

    <!-- Bootstrap の動き（Javascript）もネットから読み込んでおきます -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>