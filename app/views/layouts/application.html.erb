<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bookers2" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- 💡 ヘッダーエリア -->
    <header class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <!-- ロゴ（クリックするとルートパスへ） -->
        <%= link_to "Bookers", root_path, class: "navbar-brand" %>
        
        <div class="collapse navbar-collapse justify-content-end">
          <ul class="navbar-nav">
            <% if Current.user %>
              <!-- 💡 ログイン後のメニュー（正しいリンク先に書き換えました！） -->
              <li class="nav-item"><%= link_to "Home", user_path(Current.user), class: "nav-link text-light" %></li>
              <li class="nav-item"><%= link_to "Users", users_path, class: "nav-link text-light" %></li>
              <li class="nav-item"><%= link_to "Books", books_path, class: "nav-link text-light" %></li>
              <li class="nav-item"><%= link_to "Log out", session_path, data: { turbo_method: :delete }, class: "nav-link text-light" %></li>
            <% else %>
              <!-- 💡 ログイン前のメニュー -->
              <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link text-light" %></li>
              <li class="nav-item"><%= link_to "About", about_path, class: "nav-link text-light" %></li>
              <li class="nav-item"><%= link_to "Sign up", new_user_path, class: "nav-link text-light" %></li>
              <li class="nav-item"><%= link_to "Log in", new_session_path, class: "nav-link text-light" %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </header>

    <!-- フラッシュメッセージの共通表示エリア -->
    <% if flash[:notice] %>
      <div class="alert alert-success"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="alert alert-danger"><%= flash[:alert] %></div>
    <% end %>

    <%= yield %>
  </body>
</html>