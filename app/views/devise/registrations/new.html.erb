<div class="container mt-5">
  <div class="row">
    <div class="col-md-6 mx-auto">
      <h2>Sign up</h2>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h3><%= @user.errors.count %> errors prohibited this obj from being saved:</h3>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @user, url: user_registration_path, local: true do |f| %>
        
        <div class="form-group mb-3">
          <%= f.label :name %><br />
          <%= f.text_field :name, id: "name", autofocus: true %>
        </div>

        <div class="form-group mb-3">
          <%= f.label :email %><br />
          <%= f.email_field :email, id: "email", autocomplete: "email" %>
        </div>

        <div class="form-group mb-3">
          <%= f.label :password %><br />
          <%= f.password_field :password, id: "password", autocomplete: "new-password" %>
        </div>

        <div class="form-group mb-3">
          <%= f.label :password_confirmation %><br />
          <%= f.password_field :password_confirmation, id: "password_confirmation", autocomplete: "new-password" %>
        </div>

        <%= f.submit "Sign up", class: "btn btn-success" %>
      <% end %>
    </div>
  </div>
</div>