<div class="container px-5 px-sm-0 mt-3">
  <div class="row">
    <%# サイドバーを復活 %>
    <div class="col-md-3">
      <h2>User info</h2>
      <%= render 'users/info', user: current_user %> 
      <h2 class="mt-3">New book</h2>
      <%= render 'books/form', book: @book %>
    </div>
    
    <%# 一覧部分 %>
    <div class="col-md-8 offset-md-1">
      <h2>Users</h2>
      <table class="table">
        <thead>
          <tr>
            <th>image</th>
            <th>name</th>
            <th>フォロー数</th>
            <th>フォロワー数</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td><%= image_tag user.get_profile_image(50, 50) %></td>
              <td><%= user.name %></td>
              <td>フォロー数: <%= user.followings.count %></td>
              <td>フォロワー数: <%= user.followers.count %></td>
              <td>
                <% if user != current_user %>
                  <% if current_user.following?(user) %>
                    <%= button_to "フォロー外す", user_relationships_path(user.id), method: :delete, data: { turbo: false } %>
                  <% else %>
                    <%= button_to "フォローする", user_relationships_path(user.id), method: :post, data: { turbo: false } %>
                  <% end %>
                <% end %>
              </td>
              <td><%= link_to "Show", user_path(user) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>