<%# app/views/users/new.html.erb %>

<div class="container mt-5">
  <h2>Sign up</h2>

  <%# エラーメッセージの表示エリア（バリデーションに引っかかった場合） %>
  <% if @user.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h3><%= @user.errors.count %> errors prohibited this user from being saved:</h3>
      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# 新規登録フォーム %>
  <%= form_with model: @user, local: true do |form| %>
    
    <div class="mb-3">
      <%= form.label :name, "Name", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :email_address, "Email address", class: "form-label" %>
      <%= form.email_field :email_address, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :password, "Password", class: "form-label" %>
      <%= form.password_field :password, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :password_confirmation, "Password confirmation", class: "form-label" %>
      <%= form.password_field :password_confirmation, class: "form-control" %>
    </div>

    <div>
      <%# ボタンの文字は要件に合わせて半角スペースの有無に注意します %>
      <%= form.submit "Sign up", class: "btn btn-success" %>
    </div>
  <% end %>
</div>